{
	"name": "@kiojs/react",
	"version": "0.1.0",
	"description": "React hooks for Kio — provider, useKio, useShardState.",
	"license": "MIT",
	"author": "Sebastian Krebs",
	"homepage": "https://github.com/rynvelt/kio#readme",
	"repository": {

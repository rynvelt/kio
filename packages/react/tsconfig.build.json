{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"lib": ["ESNext", "DOM"],
		"jsx": "react-jsx"
	},
	"include": ["src/**/*"],
	"exclude": ["src/**/*.test.ts", "src/**/*.check.ts"]
}

{
	"name": "@kiojs/server",
	"version": "0.1.0",
	"description": "Server runtime for Kio — pipeline, broadcast, persistence interface, afterCommit hooks, observability.",
	"license": "MIT",
	"author": "Sebastian Krebs",
	"homepage": "https://github.com/rynvelt/kio#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rynvelt/kio.git",
		"directory": "packages/server"
	},
	"bugs": {
		"url": "https://github.com/rynvelt/kio/issues"
	},
	"keywords": [
		"kio",
		"realtime",
		"state-sync",
		"multiplayer",
		"server"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bunx tsgo -p tsconfig.build.json"
	},
	"dependencies": {
		"@kiojs/shared": "workspace:*",
		"@standard-schema/spec": "^1.1.0",
		"immer": "^11.1.4",
		"valibot": "^1.3.1"
	}
}

{
	"name": "@kiojs/transport-ws",
	"version": "0.1.0",
	"description": "Generic WebSocket client transport for Kio.",
	"license": "MIT",
	"author": "Sebastian Krebs",
	"homepage": "https://github.com/rynvelt/kio#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rynvelt/kio.git",
		"directory": "packages/transport-ws"
	},
	"bugs": {
		"url": "https://github.com/rynvelt/kio/issues"
	},
	"keywords": [
		"kio",
		"realtime",
		"state-sync",
		"multiplayer",
		"websocket",
		"transport"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "bunx tsgo -p tsconfig.build.json"
	},
	"dependencies": {
		"@kiojs/shared": "workspace:*"
	}
